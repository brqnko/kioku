  "query": "\n                    SELECT file_id, name, description, user_id,\n                           storage_id, file_size,\n                           parent_id, parent_kind,\n                           uploaded_at, changed_at\n                    FROM file\n                    WHERE parent_kind = ? AND parent_id = ?\n                    ORDER BY name ASC, file_id ASC\n                    LIMIT ?\n                    ",
