  "query": "\n                    SELECT project_id, created_by, name, description,\n                           indexed_at, last_seen_at, last_seen_file_id\n                    FROM project\n                    WHERE created_by = ?\n                    ORDER BY last_seen_at DESC, project_id DESC\n                    LIMIT ?\n                    ",
