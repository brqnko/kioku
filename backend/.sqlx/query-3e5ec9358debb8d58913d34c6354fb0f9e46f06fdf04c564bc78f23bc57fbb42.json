  "db_name": "MySQL",
  "query": "\n                    SELECT folder_id, parent_id, parent_kind,\n                           name, description, user_id,\n                           uploaded_at, changed_at\n                    FROM folder\n                    WHERE parent_kind = ? AND parent_id = ?\n                      AND (name, folder_id) > (?, ?)\n                    ORDER BY name ASC, folder_id ASC\n                    LIMIT ?\n                    ",
