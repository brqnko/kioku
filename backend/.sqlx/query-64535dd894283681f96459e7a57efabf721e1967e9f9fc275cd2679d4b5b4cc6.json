  "query": "\n                SELECT chat_id, name, user_id, project_id,\n                       started_at, last_activity_at\n                FROM chat\n                WHERE project_id = ?\n                  AND (last_activity_at, chat_id) < (?, ?)\n                ORDER BY last_activity_at DESC, chat_id DESC\n                LIMIT ?\n                ",
